{
  "version": "2.1.0",
  "log_prefix": "[人格守护演化·2.1.0]",
  "compatible": {
    "openclaw": ">=3.0.0",
    "context-engine": ">=1.0.0"
  },
  "test_config": {
    "enableGatewayRestartTest": true,
    "testTimeout": 30000,
    "testWorkspace": "gateway-test-workspace",
